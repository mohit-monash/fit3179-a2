{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 780,
  "height": 300,
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro",
      "labelColor": "#314155",
      "titleColor": "#1f2d3d"
    },
    "legend": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro"
    },
    "title": { "font": "Source Sans Pro", "fontSize": 18, "fontWeight": 600 }
  },
  "params": [
    { "name": "cityParam", "value": "Greater Sydney" },
    { "name": "yearParam", "value": 2022 }
  ],
  "data": {
    "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/data/sa3/income_by_geography_tidy.csv",
    "format": {
      "type": "csv",
      "parse": {
        "average_taxable_income": "number",
        "median_taxable_income": "number",
        "salary_wage_share": "number",
        "total_income": "number",
        "individuals": "number",
        "end_year": "number"
      }
    }
  },
  "transform": [
    { "filter": "datum.region_category == 'SA3'" },
    { "filter": "datum.end_year == yearParam" },
    {
      "lookup": "region_code",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/geo/SA3.json",
          "format": { "type": "topojson", "feature": "SA3_2021_AUST_GDA2020" }
        },
        "key": "properties.SA3_CODE21",
        "fields": [
          "properties.GCC_NAME21",
          "properties.STE_NAME21"
        ]
      }
    },
    {
      "calculate": "datum['properties.GCC_NAME21']",
      "as": "gcc_name"
    },
    {
      "calculate": "datum['properties.STE_NAME21']",
      "as": "state_name"
    },
    {
      "filter": "indexof(datum.gcc_name, 'Migratory') < 0 && indexof(datum.gcc_name, 'No usual address') < 0 && indexof(datum.gcc_name, 'Outside') < 0"
    },
    {
      "filter": "datum.gcc_name == cityParam"
    },
    {
      "calculate": "datum.state_name + '|' + yearParam",
      "as": "state_year_key"
    },
    {
      "lookup": "state_year_key",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/data/state/property_prices_yearly.csv",
          "format": {
            "type": "csv",
            "parse": {
              "mean_price_thousand": "number",
              "year": "number"
            }
          }
        },
        "key": "state_year",
        "fields": ["mean_price_thousand"]
      },
      "as": ["mean_price_thousand"]
    },
    {
      "calculate": "datum.mean_price_thousand * 1000",
      "as": "mean_price_value"
    },
    {
      "calculate": "datum.mean_price_value / datum.average_taxable_income",
      "as": "price_to_income"
    },
    {
      "joinaggregate": [
        { "op": "mean", "field": "price_to_income", "as": "metric_mean" },
        { "op": "median", "field": "price_to_income", "as": "metric_median" }
      ]
    }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "opacity": 0.75, "clip": true },
      "encoding": {
        "x": {
          "field": "price_to_income",
          "type": "quantitative",
          "bin": { "maxbins": 24 },
          "title": "Price-to-income ratio (years)"
        },
        "y": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "SA3 count"
        },
        "color": { "value": "#1b9e77" },
        "tooltip": [
          {
            "aggregate": "count",
            "title": "SA3 count"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "stroke": "#d95f02",
        "strokeDash": [6, 3],
        "strokeWidth": 2
      },
      "encoding": {
        "x": { "field": "metric_mean", "type": "quantitative" },
        "color": { "value": null }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "dy": -6,
        "fontSize": 12,
        "fill": "#d95f02"
      },
      "encoding": {
        "x": { "field": "metric_mean", "type": "quantitative" },
        "y": { "value": 0 },
        "text": { "value": "Mean (yrs)" }
      }
    },
    {
      "mark": {
        "type": "rule",
        "stroke": "#7570b3",
        "strokeDash": [2, 4],
        "strokeWidth": 2
      },
      "encoding": {
        "x": { "field": "metric_median", "type": "quantitative" },
        "color": { "value": null }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "dy": 12,
        "fontSize": 12,
        "fill": "#7570b3"
      },
      "encoding": {
        "x": { "field": "metric_median", "type": "quantitative" },
        "y": { "value": 0 },
        "text": { "value": "Median (yrs)" }
      }
    }
  ]
}
