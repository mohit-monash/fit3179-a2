{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "SA3 boundaries — TopoJSON base map",
  "width": 900,
  "height": 600,
  "background": "transparent",
  "projection": { "type": "equalEarth" },
  "data": {
    "url": "geo/SA3.json",
    "format": { "type": "topojson", "feature": "SA3_2021_AUST_GDA2020" }
  },
  "mark": { "type": "geoshape", "filled": true },
  "encoding": {
    "color": { "value": "#e5e7eb" },
    "stroke": { "value": "#ffffff" },
    "strokeWidth": { "value": 0.4 },
    "tooltip": [
      { "field": "properties.SA3_NAME21", "title": "SA3" },
      { "field": "properties.STE_NAME21", "title": "State" },
      { "field": "properties.GCC_NAME21", "title": "GCCSA" }
    ]
  },
  "config": { "view": { "stroke": "transparent" } }
}
