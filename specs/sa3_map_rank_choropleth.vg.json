{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "SA3 choropleth — placeholder join, edit the CSV path and field names to enable coloring",
  "width": 720,
  "height": 520,
  "projection": { "type": "equalEarth" },
  "data": {
    "url": "https://geo.abs.gov.au/arcgis/rest/services/ASGS2021/SA3/MapServer/1/query?where=1=1&outFields=sa3_code_2021,sa3_name_2021&outSR=4326&returnGeometry=true&geometryPrecision=5&maxAllowableOffset=0.01&f=geojson",
    "format": { "type": "json", "property": "features" }
  },
  "transform": [
    {
      "lookup": "properties.sa3_code_2021",
      "from": {
        "data": { "url": "data/your_sa3_metric.csv" },
        "key": "SA3_CODE21",
        "fields": ["value"]
      }
    }
  ],
  "mark": { "type": "geoshape", "stroke": "white", "strokeWidth": 0.5 },
  "encoding": {
    "shape": { "field": "geometry", "type": "geojson" },
    "color": {
      "field": "value",
      "type": "quantitative",
      "title": "Metric",
      "scale": { "scheme": "blues" }
    },
    "tooltip": [
      { "field": "properties.sa3_name_2021", "title": "SA3" },
      { "field": "value", "title": "Metric", "format": ".2f" }
    ]
  },
  "config": { "view": { "stroke": null }, "background": "#eef2f7" }
}
