{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "SA3 choropleth — placeholder join, edit the CSV path and field names to enable coloring",
  "width": 720,
  "height": 520,
  "projection": { "type": "equalEarth" },
  "data": {
    "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/geo/SA3.json",
    "format": { "type": "topojson", "feature": "SA3_2021_AUST_GDA2020" }
  },
  "transform": [
    {
      "lookup": "properties.SA3_CODE21",
      "from": {
        "data": { "url": "data/your_sa3_metric.csv" },
        "key": "SA3_CODE21",
        "fields": ["value"]
      }
    }
  ],
  "mark": { "type": "geoshape", "stroke": "#ffffff", "strokeWidth": 0.4 },
  "encoding": {
    "color": {
      "field": "value",
      "type": "quantitative",
      "title": "Metric",
      "scale": { "scheme": "blues" }
    },
    "tooltip": [
      { "field": "properties.SA3_NAME21", "title": "SA3" },
      { "field": "value", "title": "Metric", "format": ".2f" }
    ]
  },
  "config": { "view": { "stroke": "transparent" } }
}

