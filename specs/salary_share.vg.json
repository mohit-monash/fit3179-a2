{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 780,
  "height": 320,
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro",
      "labelColor": "#314155",
      "titleColor": "#1f2d3d"
    },
    "legend": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro"
    },
    "title": { "font": "Source Sans Pro", "fontSize": 18, "fontWeight": 600 }
  },
  "params": [
    { "name": "yearParam", "value": 2022 }
  ],
  "data": {
    "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/data/sa3/income_by_geography_tidy.csv",
    "format": {
      "type": "csv",
      "parse": {
        "salary_wage_share": "number",
        "individuals": "number",
        "end_year": "number"
      }
    }
  },
  "transform": [
    { "filter": "datum.region_category == 'State'" },
    { "filter": "datum.end_year == yearParam" },
    {
      "calculate": "datum.salary_wage_share * datum.individuals",
      "as": "salary_weighted"
    },
    {
      "calculate": "datum.salary_wage_share * 100",
      "as": "salary_share_pct"
    },
    {
      "joinaggregate": [
        { "op": "sum", "field": "salary_weighted", "as": "national_salary_weighted" },
        { "op": "sum", "field": "individuals", "as": "national_individuals" }
      ]
    },
    {
      "calculate": "(datum.national_salary_weighted / datum.national_individuals) * 100",
      "as": "national_salary_share_pct"
    }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 6 },
      "encoding": {
        "y": {
          "field": "region_name",
          "type": "nominal",
          "title": "State / territory",
          "sort": "-x"
        },
        "x": {
          "field": "salary_share_pct",
          "type": "quantitative",
          "title": "Share of residents with salary or wage income (%)",
          "axis": { "format": ".0f" }
        },
        "color": {
          "field": "salary_share_pct",
          "type": "quantitative",
          "legend": null,
          "scale": {
            "range": ["#d9e2ec", "#1b9e77"]
          }
        },
        "tooltip": [
          { "field": "region_name", "title": "State" },
          {
            "field": "salary_share_pct",
            "title": "Salary & wage share",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 6,
        "fontSize": 11,
        "fill": "#233142"
      },
      "encoding": {
        "y": {
          "field": "region_name",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "salary_share_pct",
          "type": "quantitative"
        },
        "text": { "field": "salary_share_pct", "format": ".1f" }
      }
    },
    {
      "data": { "values": [{}] },
      "transform": [
        {
          "aggregate": [
            {
              "op": "max",
              "field": "national_salary_share_pct",
              "as": "national_salary_share_pct"
            }
          ]
        }
      ],
      "mark": { "type": "rule", "stroke": "#d95f02", "strokeDash": [6, 3], "strokeWidth": 2 },
      "encoding": {
        "x": { "field": "national_salary_share_pct", "type": "quantitative" },
        "color": { "value": null }
      }
    },
    {
      "data": { "values": [{}] },
      "transform": [
        {
          "aggregate": [
            {
              "op": "max",
              "field": "national_salary_share_pct",
              "as": "national_salary_share_pct"
            }
          ]
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 6,
        "dy": -4,
        "fontSize": 12,
        "fill": "#d95f02",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": { "field": "national_salary_share_pct", "type": "quantitative" },
        "y": { "value": -6 },
        "text": { "value": "National average" }
      }
    }
  ]
}
