{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 780,
  "height": 320,
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro",
      "labelColor": "#314155",
      "titleColor": "#1f2d3d"
    },
    "legend": { "labelFont": "Source Sans Pro", "titleFont": "Source Sans Pro" },
    "title": { "font": "Source Sans Pro", "fontSize": 18, "fontWeight": 600 }
  },
  "params": [
    { "name": "cityParam", "value": "Australia" },
    { "name": "stateParam", "value": "Australia" },
    { "name": "yearParam", "value": 2022 }
  ],
  "data": {
    "url": "data/sa3/income_by_geography_tidy.csv",
    "format": {
      "type": "csv",
      "parse": {
        "total_income": "number",
        "average_taxable_income": "number",
        "individuals": "number",
        "end_year": "number"
      }
    }
  },
  "transform": [
    { "filter": "datum.region_category == 'State'" },
    { "filter": "datum.end_year == yearParam" },
    {
      "lookup": "region_name",
      "from": {
        "data": {
          "url": "data/state/property_prices_tidy.csv",
          "format": {
            "type": "csv",
            "parse": {
              "year": "number",
              "mean_price_thousand": "number"
            }
          }
        },
        "key": "state",
        "fields": ["mean_price_thousand", "quarter"],
        "transform": [
          { "filter": "datum.year == yearParam" },
          { "filter": "datum.quarter == concat('Jun-', yearParam)" }
        ]
      },
      "as": ["mean_price_thousand", "price_quarter"]
    },
    {
      "calculate": "datum.mean_price_thousand * 1000",
      "as": "mean_price_value"
    },
    {
      "calculate": "datum.mean_price_value / datum.average_taxable_income",
      "as": "price_to_income"
    },
    {
      "calculate": "'Australia'",
      "as": "national_key"
    },
    {
      "lookup": "national_key",
      "from": {
        "data": {
          "url": "data/sa3/income_by_geography_tidy.csv",
          "format": {
            "type": "csv",
            "parse": {
              "total_income": "number",
              "average_taxable_income": "number",
              "individuals": "number",
              "end_year": "number"
            }
          }
        },
        "key": "region_name",
        "fields": ["total_income", "average_taxable_income", "individuals"],
        "transform": [
          { "filter": "datum.region_category == 'Australia'" },
          { "filter": "datum.end_year == yearParam" }
        ]
      },
      "as": [
        "national_total_income",
        "national_average_income",
        "national_individuals"
      ]
    },
    {
      "lookup": "national_key",
      "from": {
        "data": {
          "url": "data/state/property_prices_tidy.csv",
          "format": {
            "type": "csv",
            "parse": {
              "year": "number",
              "mean_price_thousand": "number"
            }
          }
        },
        "key": "state",
        "fields": ["mean_price_thousand"],
        "transform": [
          { "filter": "datum.state == 'Australia'" },
          { "filter": "datum.year == yearParam" },
          { "filter": "datum.quarter == concat('Jun-', yearParam)" }
        ]
      },
      "as": ["national_mean_price_thousand"]
    },
    {
      "calculate": "(datum.national_mean_price_thousand ?? 0) * 1000",
      "as": "national_mean_price_value"
    },
    {
      "calculate": "datum.national_mean_price_value / datum.national_average_income",
      "as": "national_ratio"
    },
    {
      "calculate": "datum.region_name == stateParam && stateParam != 'Australia'",
      "as": "is_selected_state"
    }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 6 },
      "encoding": {
        "y": {
          "field": "region_name",
          "type": "nominal",
          "title": "State / Territory",
          "sort": "-x"
        },
        "x": {
          "field": "price_to_income",
          "type": "quantitative",
          "title": "Mean dwelling price divided by average taxable income (years)",
          "axis": { "format": ".1f" }
        },
        "color": {
          "condition": {
            "test": "datum.is_selected_state",
            "value": "#0f6ab4"
          },
          "value": "#c8d6e5"
        },
        "tooltip": [
          {
            "field": "region_name",
            "title": "State"
          },
          {
            "field": "price_to_income",
            "title": "Price-to-income ratio",
            "format": ".1f"
          },
          {
            "field": "mean_price_value",
            "title": "Mean dwelling price",
            "format": "$,.0f"
          },
          {
            "field": "average_taxable_income",
            "title": "Average taxable income",
            "format": "$,.0f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "stroke": "#d62728",
        "strokeDash": [6, 4],
        "strokeWidth": 2
      },
      "transform": [
        {
          "aggregate": [
            { "op": "max", "field": "national_ratio", "as": "national_ratio" }
          ]
        }
      ],
      "encoding": {
        "x": { "field": "national_ratio", "type": "quantitative" }
      }
    },
    {
      "mark": {
        "type": "text",
        "font": "Source Sans Pro",
        "fontSize": 12,
        "fontWeight": "bold",
        "fill": "#d62728",
        "align": "left",
        "baseline": "bottom",
        "dx": 6,
        "dy": -4
      },
      "transform": [
        {
          "aggregate": [
            { "op": "max", "field": "national_ratio", "as": "national_ratio" }
          ]
        }
      ],
      "encoding": {
        "x": { "field": "national_ratio" },
        "text": {
          "signal": "'National average · ' + format(datum.national_ratio, '.1f') + ' yrs'"
        },
        "y": { "value": -6 }
      }
    }
  ]
}
