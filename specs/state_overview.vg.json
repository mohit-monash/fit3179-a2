{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 780,
  "height": 320,
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro",
      "labelColor": "#314155",
      "titleColor": "#1f2d3d"
    },
    "legend": { "labelFont": "Source Sans Pro", "titleFont": "Source Sans Pro" },
    "title": { "font": "Source Sans Pro", "fontSize": 18, "fontWeight": 600 }
  },
  "params": [
    { "name": "yearParam", "value": 2022 }
  ],
  "data": {
    "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/data/sa3/income_by_geography_tidy.csv",
    "format": {
      "type": "csv",
      "parse": {
        "total_income": "number",
        "average_taxable_income": "number",
        "individuals": "number",
        "end_year": "number"
      }
    }
  },
  "transform": [
    { "filter": "datum.region_category == 'State'" },
    { "filter": "datum.end_year == yearParam" },
    {
      "calculate": "datum.region_name + '|' + yearParam",
      "as": "state_year_key"
    },
    {
      "lookup": "state_year_key",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/data/state/property_prices_yearly.csv",
          "format": {
            "type": "csv",
            "parse": {
              "mean_price_thousand": "number",
              "year": "number"
            }
          }
        },
        "key": "state_year",
        "fields": ["mean_price_thousand"]
      },
      "as": ["mean_price_thousand"]
    },
    {
      "calculate": "datum.mean_price_thousand * 1000",
      "as": "mean_price_value"
    },
    {
      "calculate": "datum.mean_price_value / datum.average_taxable_income",
      "as": "price_to_income"
    },
    {
      "calculate": "'Australia|' + yearParam",
      "as": "national_state_year_key"
    },
    {
      "lookup": "national_state_year_key",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/data/state/property_prices_yearly.csv",
          "format": {
            "type": "csv",
            "parse": {
              "mean_price_thousand": "number",
              "year": "number"
            }
          }
        },
        "key": "state_year",
        "fields": ["mean_price_thousand"]
      },
      "as": ["national_mean_price_thousand"]
    },
    {
      "calculate": "(datum.national_mean_price_thousand != null ? datum.national_mean_price_thousand : 0) * 1000",
      "as": "national_mean_price_value"
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "total_income",
          "as": "national_total_income_sum"
        },
        {
          "op": "sum",
          "field": "individuals",
          "as": "national_individuals_sum"
        }
      ]
    },
    {
      "calculate": "datum.national_total_income_sum / datum.national_individuals_sum",
      "as": "national_average_income"
    },
    {
      "calculate": "datum.national_mean_price_value / datum.national_average_income",
      "as": "national_ratio"
    },
    {
      "calculate": "datum.price_to_income >= datum.national_ratio",
      "as": "is_above_national"
    }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 6 },
      "encoding": {
        "y": {
          "field": "region_name",
          "type": "nominal",
          "title": "State / Territory",
          "sort": "-x"
        },
        "x": {
          "field": "price_to_income",
          "type": "quantitative",
          "title": "Price-to-income ratio (years)",
          "axis": { "format": ".1f" }
        },
        "color": {
          "condition": {
            "test": "datum.is_above_national",
            "value": "#1b9e77"
          },
          "value": "#d9e2ec"
        },
        "tooltip": [
          {
            "field": "region_name",
            "title": "State"
          },
          {
            "field": "price_to_income",
            "title": "Price-to-income ratio",
            "format": ".1f"
          },
          {
            "field": "mean_price_value",
            "title": "Mean dwelling price",
            "format": "$,.0f"
          },
          {
            "field": "average_taxable_income",
            "title": "Average taxable income",
            "format": "$,.0f"
          },
          {
            "field": "national_ratio",
            "title": "National benchmark",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "stroke": "#d95f02",
        "strokeDash": [6, 4],
        "strokeWidth": 2
      },
      "transform": [
        {
          "aggregate": [
            { "op": "max", "field": "national_ratio", "as": "national_ratio" }
          ]
        }
      ],
      "encoding": {
        "x": { "field": "national_ratio", "type": "quantitative" }
      }
    },
    {
      "mark": {
        "type": "text",
        "font": "Source Sans Pro",
        "fontSize": 12,
        "fontWeight": "bold",
        "fill": "#d95f02",
        "align": "left",
        "baseline": "bottom",
        "dx": 6,
        "dy": -4
      },
      "transform": [
        {
          "aggregate": [
            { "op": "max", "field": "national_ratio", "as": "national_ratio" }
          ]
        }
      ],
      "encoding": {
        "x": { "field": "national_ratio" },
        "text": { "value": "National average" },
        "y": { "value": -6 }
      }
    }
  ]
}
