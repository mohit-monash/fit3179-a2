{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 780,
  "height": 320,
  "config": {
    "view": { "stroke": null },
    "axis": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro",
      "labelColor": "#314155",
      "titleColor": "#1f2d3d"
    },
    "legend": {
      "labelFont": "Source Sans Pro",
      "titleFont": "Source Sans Pro"
    },
    "title": { "font": "Source Sans Pro", "fontSize": 18, "fontWeight": 600 }
  },
  "params": [
    { "name": "yearParam", "value": 2022 }
  ],
  "data": {
    "url": "https://raw.githubusercontent.com/mohit-monash/fit3179-a2/main/data/sa3/income_by_geography_tidy.csv",
    "format": {
      "type": "csv",
      "parse": {
        "total_income": "number",
        "average_taxable_income": "number",
        "individuals": "number",
        "end_year": "number"
      }
    }
  },
  "transform": [
    { "filter": "datum.region_category == 'State'" },
    { "filter": "datum.end_year >= 2011" },
    {
      "calculate": "datum.region_name + '|' + datum.end_year",
      "as": "state_year_key"
    },
    {
      "lookup": "state_year_key",
      "from": {
        "data": {
          "url": "data/state/property_prices_yearly.csv",
          "format": {
            "type": "csv",
            "parse": {
              "mean_price_thousand": "number",
              "year": "number"
            }
          }
        },
        "key": "state_year",
        "fields": ["mean_price_thousand"]
      },
      "as": ["mean_price_thousand"]
    },
    {
      "calculate": "datum.mean_price_thousand * 1000",
      "as": "mean_price_value"
    },
    {
      "calculate": "datum.mean_price_value / datum.average_taxable_income",
      "as": "price_to_income"
    },
    {
      "calculate": "timeParse(datum.end_year + '-06-30', '%Y-%m-%d')",
      "as": "year_date"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line",
        "strokeWidth": 2.2,
        "interpolate": "monotone"
      },
      "encoding": {
        "x": {
          "field": "year_date",
          "type": "temporal",
          "title": "Financial year",
          "axis": { "format": "%Y" }
        },
        "y": {
          "field": "price_to_income",
          "type": "quantitative",
          "title": "Price-to-income ratio (years)",
          "axis": { "format": ".1f" }
        },
        "color": {
          "field": "region_name",
          "type": "nominal",
          "title": "State / territory"
        },
        "tooltip": [
          { "field": "region_name", "title": "State" },
          { "field": "end_year", "title": "Year" },
          {
            "field": "price_to_income",
            "title": "Price-to-income",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "data": { "values": [{}] },
      "transform": [
        {
          "calculate": "timeParse(yearParam + '-06-30', '%Y-%m-%d')",
          "as": "selected_date"
        }
      ],
      "mark": {
        "type": "rule",
        "strokeDash": [6, 4],
        "stroke": "#555",
        "strokeWidth": 1.6
      },
      "encoding": {
        "x": { "field": "selected_date", "type": "temporal" }
      }
    }
  ]
}
